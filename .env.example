# Supabase Configuration
# These variables are used to connect to your Supabase project.
# They are safe to be exposed on the client-side (hence the NEXT_PUBLIC_ prefix).

# Find this in your Supabase project's API settings.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# Find this in your Supabase project's API settings.
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Ayrshare API Key
# This is a SECRET key and should NOT be prefixed with NEXT_PUBLIC_.
# It is used by the Supabase Edge Function to securely communicate with the Ayrshare API.
# You must set this as a secret for your Edge Function in the Supabase dashboard.
AYRSHARE_API_KEY=your-ayrshare-api-key
